###########################################################
# ПростоГраф — пример конфигурации.  Скопируйте в .env:
#     cp .env.example .env
# Бóльшую часть провайдеров можно настроить и в веб-интерфейсе
# (Настройки → Провайдеры) после входа — без правки этого файла.
# Полный справочник ВСЕХ переменных см. в env.example.
###########################################################

HOST=0.0.0.0
PORT=9621
CORS_ORIGINS=http://localhost:9621,http://127.0.0.1:9621

# Язык извлечения сущностей и ответов
SUMMARY_LANGUAGE=Русский
# Кэш ответов LLM выключен (нужно для корректного стриминга)
ENABLE_LLM_CACHE=false

###########################################################
# Хранилища.  По умолчанию — файловые (для теста и небольших объёмов).
# Для прод-масштаба переключите на PostgreSQL / Qdrant / Neo4j (см. env.example).
###########################################################
LIGHTRAG_KV_STORAGE=JsonKVStorage
LIGHTRAG_DOC_STATUS_STORAGE=JsonDocStatusStorage
LIGHTRAG_GRAPH_STORAGE=NetworkXStorage
LIGHTRAG_VECTOR_STORAGE=NanoVectorDBStorage

###########################################################
# Языковая модель (LLM). Любой OpenAI-совместимый эндпоинт.
#   OpenRouter  : https://openrouter.ai/api/v1
#   DeepSeek    : https://api.deepseek.com/v1
#   OpenAI      : https://api.openai.com/v1
#   Ollama      : http://host.docker.internal:11434/v1   (локально, ключ не нужен)
#   LM Studio   : http://host.docker.internal:1234/v1    (локально, ключ не нужен)
###########################################################
LLM_BINDING=openai
LLM_BINDING_HOST=https://openrouter.ai/api/v1
LLM_BINDING_API_KEY=ВПИШИТЕ_СВОЙ_КЛЮЧ
LLM_MODEL=deepseek/deepseek-chat-v3-0324
MAX_ASYNC_LLM=4

###########################################################
# Эмбеддинги.  ВНИМАНИЕ: модель нельзя менять после первой индексации!
###########################################################
EMBEDDING_BINDING=openai
EMBEDDING_BINDING_HOST=https://openrouter.ai/api/v1
EMBEDDING_BINDING_API_KEY=ВПИШИТЕ_СВОЙ_КЛЮЧ
EMBEDDING_MODEL=openai/text-embedding-3-large
EMBEDDING_DIM=3072

###########################################################
# Реранкер (опционально). null = выключен. Иначе: cohere / jina / aliyun.
###########################################################
RERANK_BINDING=null
# RERANK_MODEL=rerank-v3.5
# RERANK_BINDING_HOST=https://api.cohere.com/v2/rerank
# RERANK_BINDING_API_KEY=

###########################################################
# Парсинг документов.
# По умолчанию: .docx → нативный парсер, остальное → legacy (pypdf/openpyxl/...).
# Текстовые PDF работают сразу. Для OCR сканов поднимите MinerU/Docling и
# раскомментируйте строку ниже + укажите их эндпоинты (см. env.example).
###########################################################
# LIGHTRAG_PARSER=*:native-teP,*:legacy-R

###########################################################
# Аутентификация.
# При первом запуске создаётся admin / admin — ОБЯЗАТЕЛЬНО смените пароль в админке.
# TOKEN_SECRET генерируется автоматически и хранится в томе данных.
###########################################################
# TOKEN_EXPIRE_HOURS=48
# LIGHTRAG_API_KEY=
